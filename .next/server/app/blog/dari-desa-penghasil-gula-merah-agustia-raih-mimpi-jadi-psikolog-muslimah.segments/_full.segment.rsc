d:[["$","title","0",{"children":"Dari Desa Penghasil Gula Merah, Agustia Raih Mimpi Jadi Psikolog Muslimah"}],["$","meta","1",{"name":"description","content":"Di balik setiap prestasi, ada kisah perjuangan yang jarang terlihat. Agustia, alumni YES Sinjai angkatan 2, lahir dari keluarga petani dan pembuat gula merah."}],["$","meta","2",{"property":"og:title","content":"Dari Desa Penghasil Gula Merah, Agustia Raih Mimpi Jadi Psikolog Muslimah"}],["$","meta","3",{"property":"og:description","content":"Di balik setiap prestasi, ada kisah perjuangan yang jarang terlihat. Agustia, alumni YES Sinjai angkatan 2, lahir dari keluarga petani dan pembuat gula merah."}],["$","meta","4",{"property":"og:url","content":"https://www.youthekselensia.id/blog/dari-desa-penghasil-gula-merah-agustia-raih-mimpi-jadi-psikolog-muslimah"}],["$","meta","5",{"property":"og:image","content":"https://cdn.sanity.io/images/lxtfznya/production/2cbaeb5b79c88c83e925eb6f21c55a5ec4b49f18-1280x720.jpg?rect=0,24,1280,672&w=1200&h=630"}],["$","meta","6",{"property":"og:image:width","content":"1200"}],["$","meta","7",{"property":"og:image:height","content":"630"}],["$","meta","8",{"property":"og:image:alt","content":"Dari Desa Penghasil Gula Merah, Agustia Raih Mimpi Jadi Psikolog Muslimah"}],["$","meta","9",{"property":"og:type","content":"article"}],["$","meta","10",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","11",{"name":"twitter:title","content":"Dari Desa Penghasil Gula Merah, Agustia Raih Mimpi Jadi Psikolog Muslimah"}],["$","meta","12",{"name":"twitter:description","content":"Di balik setiap prestasi, ada kisah perjuangan yang jarang terlihat. Agustia, alumni YES Sinjai angkatan 2, lahir dari keluarga petani dan pembuat gula merah."}],["$","meta","13",{"name":"twitter:image","content":"https://cdn.sanity.io/images/lxtfznya/production/2cbaeb5b79c88c83e925eb6f21c55a5ec4b49f18-1280x720.jpg?rect=0,24,1280,672&w=1200&h=630"}],["$","meta","14",{"name":"twitter:image:width","content":"1200"}],["$","meta","15",{"name":"twitter:image:height","content":"630"}],["$","meta","16",{"name":"twitter:image:alt","content":"Dari Desa Penghasil Gula Merah, Agustia Raih Mimpi Jadi Psikolog Muslimah"}],["$","link","17",{"rel":"shortcut icon","href":"/images/logo-yes.png"}],["$","link","18",{"rel":"icon","href":"/favicon.ico?favicon.a7c0c6c0.ico","sizes":"256x256","type":"image/x-icon"}],["$","link","19",{"rel":"icon","href":"/images/logo-yes.png"}],["$","link","20",{"rel":"apple-touch-icon","href":"/images/logo-yes.png"}],["$","$L1d","21",{}]]
1e:I[522016,["/_next/static/chunks/60ad5f9748ae9463.js"],""]
f:["$","strong","3a96ad40e0d1",{"className":"text-blue-900 font-bold","children":["Beasiswa YES "]}]
10:["$","p","5fdf2bb220c3",{"className":"text-slate-600 leading-relaxed mb-6","children":["Agustia jatuh hati bukan hanya karena beasiswa ini memberi dukungan finansial dan bimbingan masuk PTN, tapi juga karena ada pembinaan Qur’an dan akhlak. Sejak awal, ia memang ingin lebih dekat dengan Al-Qur’an dan mencari guru yang bisa membimbingnya dalam hafalan dan adab."]}]
11:["$","p","869c31f949af",{"className":"text-slate-600 leading-relaxed mb-6","children":["“Saya merasa Beasiswa YES bukan hanya tentang kuliah. Tapi tentang menjadi pribadi yang utuh—berilmu dan berakhlak.”"]}]
12:["$","p","50edbece6641",{"className":"text-slate-600 leading-relaxed mb-6","children":["Selama menjadi Penerima Manfaat YES, Agustia tidak hanya dibimbing untuk mempersiapkan seleksi masuk perguruan tinggi. Ia juga diajak untuk merancang ",["$","strong","07ab308bd686",{"className":"text-blue-900 font-bold","children":["life-plan"]}],", memetakan karier, dan bahkan diajarkan kemampuan public speaking—hal yang sebelumnya sangat ia takuti."]}]
13:["$","p","f9e6a2a4bf35",{"className":"text-slate-600 leading-relaxed mb-6","children":["Sedikit demi sedikit, ia tumbuh. Agustia jadi percaya diri bicara di depan umum. Ia juga makin aktif di sekolah, hingga akhirnya dipercaya menjadi ",["$","strong","02411fdcbb47",{"className":"text-blue-900 font-bold","children":["Ketua OSIS"]}],"."]}]
14:["$","p","2e11712136f8",{"className":"text-slate-600 leading-relaxed mb-6","children":["“Dulu saya ragu untuk bicara di depan kelas. Tapi di YES, saya belajar bahwa semua bisa dilatih. Termasuk keberanian.”"]}]
15:["$","p","5fb87df93fb0",{"className":"text-slate-600 leading-relaxed mb-6","children":["Agustia memilih ",["$","strong","b5447507674b",{"className":"text-blue-900 font-bold","children":["Psikologi "]}],"sebagai jurusan kuliah. Baginya, ini bukan sekadar pilihan akademik—tapi jalan untuk memahami manusia, dan lebih dalam lagi, memahami dirinya sendiri."]}]
16:["$","p","4a207b9120bd",{"className":"text-slate-600 leading-relaxed mb-6","children":["Ia belajar dengan keras, menjaga nilai akademik dan tetap aktif di berbagai kegiatan. Dan pada tahun itu juga, ia ",["$","strong","c007f827eae8",{"className":"text-blue-900 font-bold","children":["lolos masuk Universitas Negeri Makassar lewat jalur SNBP."]}]]}]
17:["$","p","c345035a58ad",{"className":"text-slate-600 leading-relaxed mb-6","children":["“Psikologi mengajarkan saya bahwa setiap orang punya cerita, punya luka, dan punya potensi untuk tumbuh.”"]}]
18:["$","p","04b202c5c4c0",{"className":"text-slate-600 leading-relaxed mb-6","children":["Selama perjalanan ini, Agustia tak pernah lupa satu hal: ",["$","strong","a15af31d1038",{"className":"text-blue-900 font-bold","children":["doa dan ridho dari kedua orang tua."]}],"Ia tahu, kerja kerasnya tak akan berarti tanpa restu mereka. Setiap langkah ia iringi dengan doa, dan setiap prestasi ia persembahkan untuk orang tua yang setiap hari menjerang gula merah di dapur sederhana mereka."]}]
19:["$","p","0f290d4c7855",{"className":"text-slate-600 leading-relaxed mb-6","children":["Kini, Agustia menjalani kuliah dengan semangat baru. Ia tak hanya belajar untuk dirinya sendiri, tapi juga berharap kelak bisa ",["$","strong","a68aa6e63a29",{"className":"text-blue-900 font-bold","children":["kembali ke masyarakat"]}],", membantu orang lain memahami kesehatan mental dan tumbuh sebagai pribadi yang kuat secara spiritual dan emosional."]}]
1a:["$","p","91119291ef8b",{"className":"text-slate-600 leading-relaxed mb-6","children":["“Angin tak berhembus untuk menggoyahkan pepohonan, tapi untuk menguji kekuatan akarnya.” — Sayyidina Ali bin Abi Thalib"]}]
1b:["$","p","85e6dc4c5853",{"className":"text-slate-600 leading-relaxed mb-6","children":["YES telah menjadi akar kuat dalam perjalanan Agustia. Dari sebuah desa penghasil gula merah, ia kini melangkah menuju mimpi—dengan hati yang manis, tekad yang kuat, dan akhlak yang tumbuh bersama ilmu."]}]
